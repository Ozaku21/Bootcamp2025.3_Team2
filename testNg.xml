<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TBC Playwright Test Suite" parallel="tests" thread-count="2" verbose="1">

    <test name="Chromium Desktop">
        <parameter name="browser" value="chromium"/>
        <parameter name="deviceType" value="DESKTOP"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.CurrencyExchangeTest"/>
        </classes>
    </test>

    <test name="Firefox Desktop">
        <parameter name="browser" value="edge"/>
        <parameter name="deviceType" value="DESKTOP"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.CurrencyExchangeTest"/>
        </classes>
    </test>

    <test name="WebKit Desktop">
        <parameter name="browser" value="webkit"/>
        <parameter name="deviceType" value="DESKTOP"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.CurrencyExchangeTest"/>
        </classes>
    </test>

    <test name="Phone">
        <parameter name="browser" value="chromium"/>
        <parameter name="deviceType" value="PHONE"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.CurrencyExchangeTest"/>
        </classes>
    </test>
</suite>