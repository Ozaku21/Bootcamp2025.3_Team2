<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TBC Playwright Test Suite" parallel="tests" thread-count="2" verbose="1">
    <test name="Chromium Desktop">
        <parameter name="Browser" value="chromium"/>
        <parameter name="DeviceType" value="desktop"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.Executor"/>
        </classes>
    </test>
    <test name="Chromium Mobile">
        <parameter name="Browser" value="chromium"/>
        <parameter name="DeviceType" value="mobile"/>
        <classes>
            <class name="ge.tbc.testautomation.ui.Executor"/>
        </classes>
    </test>
</suite>